---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { type CollectionEntry, getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const resumes = await getCollection("resume");
  return resumes.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"resume"> };
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  pageTitle={`${post.data.title} · Michifumi`}
  description={post.data.description || "Michifumi's Resume"}
>
  <div class="mx-auto flex w-full flex-col gap-10">
    <article
      class="prose prose-invert prose-headings:tracking-tight w-full max-w-3xl space-y-6 mx-auto lg:max-w-4xl xl:max-w-5xl"
    >
      <header
        class="rounded-3xl border border-white/5 bg-soft/70 p-8 shadow-soft"
      >
        <h1 class="mt-2 text-3xl font-bold text-white md:text-4xl">
          {post.data.title}
        </h1>
        {
          post.data.description && (
            <p class="mt-3 max-w-2xl text-base text-gray-300">
              {post.data.description}
            </p>
          )
        }
      </header>
      <section
        class="rounded-3xl border border-white/5 bg-soft/70 p-8 shadow-soft text-base leading-relaxed text-gray-200"
      >
        <Content />
      </section>
    </article>
  </div>
</BaseLayout>
